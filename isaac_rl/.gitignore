# =============================================================================
# isaac_rl/.gitignore
#
# Covers parent-level concerns inside isaac_rl/. Most generated artifacts
# (logs, outputs, USDs, egg-info, pycache) are already handled by the
# generator's .gitignore at isaac_rl/holoassist_tasks/.gitignore. This file
# is a safety net for anything that might land at the isaac_rl/ level itself.
# =============================================================================

# -----------------------------------------------------------------------------
# Training run artifacts (TensorBoard events, model checkpoints, hydra outputs)
# -----------------------------------------------------------------------------
logs/
**/logs/
**/outputs/
**/wandb/
**/runs/

# -----------------------------------------------------------------------------
# Python build / install artifacts
# -----------------------------------------------------------------------------
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.egg-info/
**/build/
**/dist/

# -----------------------------------------------------------------------------
# Exported policies (regenerate from training checkpoints via play.py)
#
# Note: USD generation/ignore rules live in holoassist_tasks/.gitignore
# (which has `**/*.usd` covering anywhere inside the project). The mesh
# source files (.dae, .stl, etc.) are NOT ignored — they ship with the URDF.
# -----------------------------------------------------------------------------
**/exported/
*.onnx
*.pt
*.zip

# -----------------------------------------------------------------------------
# Editor / OS noise
# -----------------------------------------------------------------------------
.vscode/.python.env
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Isaac Sim runtime cache / crash dumps (if any leak into this tree)
# -----------------------------------------------------------------------------
**/*.dmp
**/.thumbs/
