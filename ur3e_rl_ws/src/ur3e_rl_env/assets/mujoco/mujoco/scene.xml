<mujoco model="ur3e_pick_place">

  <!-- Robot MJCF included at top level so worldbodies merge.
       robot.xml sets: compiler angle="radian", fusestatic="false",
       base_link at pos="0 0 1.1" quat="0 0 0 1" (yaw=π). -->
  <include file="robot.xml"/>

  <option
    timestep="0.002"
    gravity="0 0 -9.81"
    integrator="implicitfast"
    cone="elliptic"
    impratio="10"/>

  <default>
    <default class="cube">
      <geom type="box" size="0.02 0.02 0.02"
            mass="0.05" friction="0.8 0.005 0.0001"
            condim="4" solref="0.01 1"/>
    </default>
  </default>

  <worldbody>

    <!-- Ground plane -->
    <geom name="floor" type="plane" size="3 3 0.1"
          rgba="0.55 0.57 0.60 1" friction="1 0.005 0.0001"/>

    <!-- Lighting -->
    <light name="sun" directional="true" pos="0 0 5"
           dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"/>

    <!-- Table: placed at (-0.031, 0, 0.29) to match Gazebo world SDF.
         Tabletop surface lands at world z = 0.29 + 0.780 = 1.07. -->
    <body name="table" pos="-0.031 0 0.29">
      <geom name="tabletop" type="box"
            pos="0 -0.210 0.780" size="0.425 0.35 0.02"
            rgba="0.70 0.50 0.30 1" friction="0.9 0.005 0.0001"/>
      <geom name="shelf" type="box"
            pos="0 -0.210 0.420" size="0.39 0.31 0.015"
            rgba="0.65 0.45 0.25 1"/>
    </body>

    <!-- Cubes — free bodies. Positions match Gazebo world SDF defaults. -->
    <body name="cube_0" pos="0.1 -0.40 1.11">
      <freejoint name="cube_0_joint"/>
      <geom class="cube" rgba="0.86 0.10 0.12 1" name="cube_0_geom"/>
    </body>
    <body name="cube_1" pos="0.1 -0.25 1.11">
      <freejoint name="cube_1_joint"/>
      <geom class="cube" rgba="0.20 0.70 0.25 1" name="cube_1_geom"/>
    </body>
    <body name="cube_2" pos="-0.1 -0.25 1.11">
      <freejoint name="cube_2_joint"/>
      <geom class="cube" rgba="0.20 0.35 0.80 1" name="cube_2_geom"/>
    </body>
    <body name="cube_3" pos="-0.1 -0.40 1.11">
      <freejoint name="cube_3_joint"/>
      <geom class="cube" rgba="0.85 0.78 0.10 1" name="cube_3_geom"/>
    </body>

    <!-- Bin sites — target locations. Positions from pick_place_world.sdf. -->
    <site name="bin_0" type="box" size="0.06 0.06 0.005"
          pos="0.28 0.0 1.083" rgba="0.08 0.44 0.36 0.5"/>
    <site name="bin_1" type="box" size="0.06 0.06 0.005"
          pos="-0.28 0.0 1.083" rgba="0.10 0.30 0.70 0.5"/>

  </worldbody>

  <!-- Six-DOF arm actuators. Joint names confirmed from test_urdf_load output. -->
  <actuator>
    <position name="shoulder_pan"  joint="shoulder_pan_joint"
              kp="500" kv="50" ctrlrange="-6.2832 6.2832" ctrllimited="true"/>
    <position name="shoulder_lift" joint="shoulder_lift_joint"
              kp="500" kv="50" ctrlrange="-6.2832 6.2832" ctrllimited="true"/>
    <position name="elbow"         joint="elbow_joint"
              kp="500" kv="50" ctrlrange="-6.2832 6.2832" ctrllimited="true"/>
    <position name="wrist_1"       joint="wrist_1_joint"
              kp="200" kv="20" ctrlrange="-6.2832 6.2832" ctrllimited="true"/>
    <position name="wrist_2"       joint="wrist_2_joint"
              kp="200" kv="20" ctrlrange="-6.2832 6.2832" ctrllimited="true"/>
    <position name="wrist_3"       joint="wrist_3_joint"
              kp="200" kv="20" ctrlrange="-6.2832 6.2832" ctrllimited="true"/>
  </actuator>

  <!-- Exclude self-collisions between adjacent links. -->
  <contact>
    <exclude body1="base_link_inertia" body2="shoulder_link"/>
    <exclude body1="shoulder_link"     body2="upper_arm_link"/>
    <exclude body1="upper_arm_link"    body2="forearm_link"/>
    <exclude body1="forearm_link"      body2="wrist_1_link"/>
    <exclude body1="wrist_1_link"      body2="wrist_2_link"/>
    <exclude body1="wrist_2_link"      body2="wrist_3_link"/>
    <exclude body1="wrist_3_link"      body2="onrobot_rg2_base_link"/>
    <exclude body1="onrobot_rg2_base_link" body2="left_outer_knuckle"/>
    <exclude body1="onrobot_rg2_base_link" body2="right_outer_knuckle"/>
    <exclude body1="onrobot_rg2_base_link" body2="left_inner_knuckle"/>
    <exclude body1="onrobot_rg2_base_link" body2="right_inner_knuckle"/>
    <exclude body1="left_outer_knuckle"    body2="left_inner_finger"/>
    <exclude body1="right_outer_knuckle"   body2="right_inner_finger"/>
  </contact>

</mujoco>
