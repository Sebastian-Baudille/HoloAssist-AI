<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <!--
    RG2 gripper — simplified geometry.
    The original STL files (rg2/visual/ and rg2/collision/) are corrupted and
    cannot be parsed by Ogre3D (RViz) or ODE (Gazebo physics). Both visual and
    collision geometry have been replaced with bounding-box approximations so
    Gazebo can run without crashing. The kinematic chain (joint origins) is
    unchanged, so the TCP frame and all transforms remain correct.
  -->

  <xacro:macro name="rg2_inertial" params="mass">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="1.0e-3" ixy="1.0e-6" ixz="1.0e-6"
               iyy="1.0e-3" iyz="1.0e-6" izz="1.0e-3"/>
    </inertial>
  </xacro:macro>

  <!-- Box-approximation link: visual and collision are the same simple box -->
  <xacro:macro name="rg2_box_link" params="name sx sy sz rgba mass">
    <link name="${name}">
      <xacro:rg2_inertial mass="${mass}"/>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${sx} ${sy} ${sz}"/></geometry>
        <material name="${name}_mat"><color rgba="${rgba}"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${sx} ${sy} ${sz}"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="rg2_fixed" params="prefix parent">

    <!-- Gripper body -->
    <xacro:rg2_box_link name="${prefix}onrobot_rg2_base_link"
      sx="0.10" sy="0.08" sz="0.04"
      rgba="0.80 0.80 0.80 1.0" mass="0.78"/>
    <joint name="${prefix}tool0-rg2_base" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}onrobot_rg2_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Left outer knuckle -->
    <xacro:rg2_box_link name="${prefix}left_outer_knuckle"
      sx="0.018" sy="0.018" sz="0.04"
      rgba="0.80 0.80 0.80 1.0" mass="0.05"/>
    <joint name="${prefix}left_outer_knuckle_joint" type="fixed">
      <parent link="${prefix}onrobot_rg2_base_link"/>
      <child link="${prefix}left_outer_knuckle"/>
      <origin xyz="0 -0.017178 0.125797" rpy="0 0 0"/>
    </joint>

    <!-- Left inner knuckle -->
    <xacro:rg2_box_link name="${prefix}left_inner_knuckle"
      sx="0.014" sy="0.014" sz="0.08"
      rgba="0.80 0.80 0.80 1.0" mass="0.05"/>
    <joint name="${prefix}left_inner_knuckle_joint" type="fixed">
      <parent link="${prefix}onrobot_rg2_base_link"/>
      <child link="${prefix}left_inner_knuckle"/>
      <origin xyz="0 -0.007678 0.142297" rpy="0 0 0"/>
    </joint>

    <!-- Left inner finger -->
    <xacro:rg2_box_link name="${prefix}left_inner_finger"
      sx="0.014" sy="0.014" sz="0.07"
      rgba="0.08 0.08 0.08 1.0" mass="0.05"/>
    <joint name="${prefix}left_inner_finger_joint" type="fixed">
      <parent link="${prefix}left_outer_knuckle"/>
      <child link="${prefix}left_inner_finger"/>
      <origin xyz="0 -0.039592 0.038177" rpy="0 0 0"/>
    </joint>

    <!-- Right outer knuckle -->
    <xacro:rg2_box_link name="${prefix}right_outer_knuckle"
      sx="0.018" sy="0.018" sz="0.04"
      rgba="0.80 0.80 0.80 1.0" mass="0.05"/>
    <joint name="${prefix}right_outer_knuckle_joint" type="fixed">
      <parent link="${prefix}onrobot_rg2_base_link"/>
      <child link="${prefix}right_outer_knuckle"/>
      <origin xyz="0 0.017178 0.125797" rpy="0 0 3.141592653589793"/>
    </joint>

    <!-- Right inner knuckle -->
    <xacro:rg2_box_link name="${prefix}right_inner_knuckle"
      sx="0.014" sy="0.014" sz="0.08"
      rgba="0.80 0.80 0.80 1.0" mass="0.05"/>
    <joint name="${prefix}right_inner_knuckle_joint" type="fixed">
      <parent link="${prefix}onrobot_rg2_base_link"/>
      <child link="${prefix}right_inner_knuckle"/>
      <origin xyz="0 0.007678 0.142297" rpy="0 0 3.141592653589793"/>
    </joint>

    <!-- Right inner finger -->
    <xacro:rg2_box_link name="${prefix}right_inner_finger"
      sx="0.014" sy="0.014" sz="0.07"
      rgba="0.08 0.08 0.08 1.0" mass="0.05"/>
    <joint name="${prefix}right_inner_finger_joint" type="fixed">
      <parent link="${prefix}right_outer_knuckle"/>
      <child link="${prefix}right_inner_finger"/>
      <origin xyz="0 -0.039592 0.038177" rpy="0 0 0"/>
    </joint>

    <!-- TCP frame — unchanged -->
    <link name="${prefix}gripper_tcp"/>
    <joint name="${prefix}tcp_joint" type="fixed">
      <parent link="${prefix}onrobot_rg2_base_link"/>
      <child link="${prefix}gripper_tcp"/>
      <origin xyz="0 0 0.218" rpy="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>
