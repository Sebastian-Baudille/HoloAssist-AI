<?xml version="1.0" ?>
<!--
  Auto-generated from worlds/table_cubes.sdf.jinja2 + config/sim_params.yaml.
  DO NOT EDIT THIS FILE DIRECTLY — edit sim_params.yaml and re-launch.
-->
<sdf version="1.9">
  <world name="table_cubes_world">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
{% if camera.imu.enabled %}
    <plugin filename="ignition-gazebo-imu-system"
            name="ignition::gazebo::systems::Imu"/>
{% endif %}

    <scene>
      <ambient>{{ world.ambient[0] }} {{ world.ambient[1] }} {{ world.ambient[2] }} 1</ambient>
      <background>{{ world.background[0] }} {{ world.background[1] }} {{ world.background[2] }} 1</background>
      <grid>false</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.3 0.2 -1</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>{{ world.ground_size }} {{ world.ground_size }}</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>{{ world.ground_size }} {{ world.ground_size }}</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Table -->
    <model name="table">
      <static>true</static>
      <pose>{{ table.pose | join(' ') }}</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>{{ table.size | join(' ') }}</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>{{ table.size | join(' ') }}</size></box></geometry>
          <material>
            <ambient>{{ table.color | join(' ') }}</ambient>
            <diffuse>{{ table.color | join(' ') }}</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cubes -->
{% for cube in cubes %}
{% set sx = cube.size[0] %}
{% set sy = cube.size[1] %}
{% set sz = cube.size[2] %}
{% set m  = cube.mass %}
{# Inertia for a solid cuboid: I = m/12 * (a^2 + b^2) #}
{% set ixx = m / 12.0 * (sy*sy + sz*sz) %}
{% set iyy = m / 12.0 * (sx*sx + sz*sz) %}
{% set izz = m / 12.0 * (sx*sx + sy*sy) %}
    <model name="{{ cube.name }}">
      <pose>{{ cube.pose | join(' ') }}</pose>
      <link name="link">
        <inertial>
          <mass>{{ m }}</mass>
          <inertia>
            <ixx>{{ '%.6e' % ixx }}</ixx>
            <iyy>{{ '%.6e' % iyy }}</iyy>
            <izz>{{ '%.6e' % izz }}</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><box><size>{{ cube.size | join(' ') }}</size></box></geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>{{ cube.size | join(' ') }}</size></box></geometry>
          <material>
            <ambient>{{ cube.color | join(' ') }}</ambient>
            <diffuse>{{ cube.color | join(' ') }}</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
      </link>
    </model>
{% endfor %}

    <!--
      Intel RealSense D435i (simulated).
        Model : {{ camera.name }}
        Link  : {{ camera.name }}_link  — body frame, +X = look direction.
        Sensors (imu_sensor, rgbd) live directly on this link so the camera
        looks along the body +X axis, which the user's pose already aims at
        the scene.  Scoped frame_id published by Ignition:
          "{{ camera.name }}/{{ camera.name }}_link/rgbd"
    -->
    <model name="{{ camera.name }}">
      <static>true</static>
      <pose>{{ camera.pose | join(' ') }}</pose>

      <link name="{{ camera.name }}_link">
        <visual name="body">
          <geometry><box><size>0.090 0.025 0.025</size></box></geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.10 0.10 0.10 1</diffuse>
            <specular>0.4 0.4 0.4 1</specular>
          </material>
        </visual>
{% if camera.imu.enabled %}
        <sensor name="imu_sensor" type="imu">
          <topic>{{ camera.imu.topic }}</topic>
          <update_rate>{{ camera.imu.update_rate }}</update_rate>
          <always_on>1</always_on>
        </sensor>
{% endif %}
        <!-- rgbd sensor on the same link — looks along the link's +X axis -->
        <sensor name="rgbd" type="rgbd_camera">
          <topic>{{ camera.topic }}</topic>
          <update_rate>{{ camera.update_rate }}</update_rate>
          <always_on>1</always_on>
          <visualize>true</visualize>
          <camera>
            <horizontal_fov>{{ '%.6f' % (camera.horizontal_fov_deg * 3.141592653589793 / 180.0) }}</horizontal_fov>
            <image>
              <width>{{ camera.width }}</width>
              <height>{{ camera.height }}</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>{{ camera.near_clip }}</near>
              <far>{{ camera.far_clip }}</far>
            </clip>
            <depth_camera>
              <clip>
                <near>{{ camera.near_clip }}</near>
                <far>{{ camera.far_clip }}</far>
              </clip>
            </depth_camera>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </camera>
        </sensor>
      </link>
    </model>

  </world>
</sdf>
