# Auto-generated from ros_gz_bridge.yaml.jinja2 + sim_params.yaml
# Bridges Ignition Gazebo topics to ROS 2 topics.
- ros_topic_name: "/clock"
  gz_topic_name: "/clock"
  ros_type_name: "rosgraph_msgs/msg/Clock"
  gz_type_name: "ignition.msgs.Clock"
  direction: GZ_TO_ROS

- ros_topic_name: "{{ camera.topic }}/image"
  gz_topic_name: "{{ camera.topic }}/image"
  ros_type_name: "sensor_msgs/msg/Image"
  gz_type_name: "ignition.msgs.Image"
  direction: GZ_TO_ROS

- ros_topic_name: "{{ camera.topic }}/depth_image"
  gz_topic_name: "{{ camera.topic }}/depth_image"
  ros_type_name: "sensor_msgs/msg/Image"
  gz_type_name: "ignition.msgs.Image"
  direction: GZ_TO_ROS

- ros_topic_name: "{{ camera.topic }}/points"
  gz_topic_name: "{{ camera.topic }}/points"
  ros_type_name: "sensor_msgs/msg/PointCloud2"
  gz_type_name: "ignition.msgs.PointCloudPacked"
  direction: GZ_TO_ROS

- ros_topic_name: "{{ camera.topic }}/camera_info"
  gz_topic_name: "{{ camera.topic }}/camera_info"
  ros_type_name: "sensor_msgs/msg/CameraInfo"
  gz_type_name: "ignition.msgs.CameraInfo"
  direction: GZ_TO_ROS
{% if camera.imu.enabled %}

- ros_topic_name: "{{ camera.imu.topic }}"
  gz_topic_name: "{{ camera.imu.topic }}"
  ros_type_name: "sensor_msgs/msg/Imu"
  gz_type_name: "ignition.msgs.IMU"
  direction: GZ_TO_ROS
{% endif %}
